{
  "name": "appraisal360-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "build:dev": "npm --prefix frontend run build:dev",
    "lint": "npm --prefix frontend run lint",
    "preview": "npm --prefix frontend run preview",
    "test": "npm --prefix frontend run test",
    "test:watch": "npm --prefix frontend run test:watch",
    "infra:up": "docker compose --env-file database/.env -f database/docker-compose.yml up -d",
    "infra:down": "docker compose --env-file database/.env -f database/docker-compose.yml down",
    "infra:logs": "docker compose --env-file database/.env -f database/docker-compose.yml logs -f",
    "infra:reset": "docker compose --env-file database/.env -f database/docker-compose.yml down -v --remove-orphans",
    "backend:dev": "cd backend && uvicorn src.main:app --reload --host 0.0.0.0 --port 8000",
    "db:seed": "python database/scripts/seed_postgresql.py",
    "db:seed:creds": "python database/scripts/seed_postgresql.py --print-creds"
  },
  "dependencies": {},
  "devDependencies": {}
}
