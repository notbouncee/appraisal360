APP_NAME=appraisal360-api
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8080

# Security
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=appraisal360
POSTGRES_USER=appraisal_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://appraisal_user:change_me@localhost:5432/appraisal360

# RustFS (S3-compatible)
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=change_access_key
RUSTFS_SECRET_KEY=change_secret_key
RUSTFS_REGION=us-east-1
RUSTFS_BUCKET_PROFILE_IMAGES=profile-images
