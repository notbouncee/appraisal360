# PostgreSQL bootstrap
POSTGRES_HOST=localhost
POSTGRES_DB=appraisal360
POSTGRES_USER=appraisal_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# RustFS service (S3-compatible)
RUSTFS_IMAGE=rustfs/rustfs:latest
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_ACCESS_KEY=change_access_key
RUSTFS_SECRET_KEY=change_secret_key
RUSTFS_ROOT_USER=admin
RUSTFS_ROOT_PASSWORD=change_root_password
RUSTFS_BUCKET_PROFILE_IMAGES=profile-images
RUSTFS_REGION=us-east-1
